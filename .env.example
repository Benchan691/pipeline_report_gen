# eDrive credentials (copy to .env and fill in)
EDRIVE_USERNAME=your_username
EDRIVE_PASSWORD=your_password

# Remote eDrive folder path (parent destination for each run subfolder)
EDRIVE_REMOTE_PATH=Ben Chan/weekly-reports

# eDrive server URL (required)
EDRIVE_BASE_URL=https://edrive.citictel-cpc.com

# Firecrawl API key (required when search_provider is firecrawl or SearXNG fallback is enabled)
FIRECRAWL_API_KEY=fc-your-api-key

# Email
EMAIL_RECEIVER=you@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
